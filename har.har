        "content" : {
          "size" : 44085,
          "compression" : 0,
          "mimeType" : "text/html; charset=UTF-8",
          "text" : "<form class=\"row\" id=\"edit_mission_shift\" name=\"edit_mission_shift\">\r\n    \n<input type=\"hidden\" name=\"mission_id\" value=\"18250\" />\n    <input type=\"hidden\" name=\"shift_id\" id=\"shift_id\" value=\"31023\"/>\r\n    <div class=\"col s12 pt-1\">\r\n                <div class=\"col s12\">\r\n        <label class=\"label-clear\" for=\"shift_end_date\">Τύπος Βάρδιας</label>\r\n            <select name=\"mission_type_id\" id=\"mission_type_id\" class=\"error validate\">\r\n                <option value=\"\">Επιλέξτε τύπο βάρδιας</option>\r\n                                <option value=\"71\"  selected=\"selected\" >BLS “ΒΑΣΙΚΗ ΥΠΟΣΤΗΡΙΞΗ ΖΩΗΣ’’</option>\r\n                                <option value=\"56\" >ΔΡΑΣΗ ΠΡΟΛΗΨΗΣ</option>\r\n                                <option value=\"57\" >ΕΘΕΛΟΝΤΙΚΗ ΔΡΑΣΤΗΡΙΟΤΗΤΑ</option>\r\n                                <option value=\"36\" >ΕΚΠΑΙΔΕΥΣΗ Α΄ ΒΟΗΘΕΙΩΝ ΣΕ ΠΟΛΙΤΕΣ</option>\r\n                                <option value=\"86\" >ΕΚΠΑΙΔΕΥΣΗ Α' ΒΟΗΘΕΙΕΣ ΓΙΑ ΣΚΥΛΟΥΣ</option>\r\n                                <option value=\"33\" >ΕΚΠΑΙΔΕΥΣΗ ΔΟΚΙΜΩΝ ΣΑΜΑΡΕΙΤΩΝ</option>\r\n                                <option value=\"83\" >ΕΚΠΑΙΔΕΥΣΗ ΕΝΕΡΓΟΠΟΙΗΣΗΣ ΑΝΕΝΕΡΓΩΝ ΕΘΕΛΟΝΤΩΝ</option>\r\n                                <option value=\"60\" >ΝΑΥΑΓΟΣΩΣΤΙΚΗ ΚΑΛΥΨΗ</option>\r\n                                <option value=\"85\" >Τ.Ε.Π. ΔΟΚΙΜΩΝ</option>\r\n                                <option value=\"16\" >ΥΓΕΙΟΝΟΜΙΚΗ ΚΑΛΥΨΗ</option>\r\n                                <option value=\"81\" >ΥΠΟΧΡΕΩΤΙΚΗ ΕΤΗΣΙΑ ΕΚΠΑΙΔΕΥΣΗ ΕΘΕΛΟΝΤΗ</option>\r\n                            </select>\r\n            <!--<label for=\"last_name\">Server</label>-->\r\n        </div>\r\n    </div>\r\n    <div class=\"row\" >\r\n        <div class=\"col s12 m12 l12 pt-5\">\r\n            <div class=\"col s12 m-0\">\r\n                <label for=\"admin_member_id\">Υπεύθυνος βάρδιας</label>\r\n                0                <