          "text" : "<!DOCTYPE html>\n<html class=\"loading\" lang=\"en\" data-textdirection=\"ltr\">\n<head>\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui\">\r\n    <title>Δημιουργία νέας αποστολής- Τμήμα ΠΑΤΡΑ - Ε.Ε.Σ. CRM - Τ. ΣΑΜΑΡΕΙΤΩΝ</title>\r\n    <link rel=\"apple-touch-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\r\n    <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\r\n    <!-- BEGIN: VENDOR CSS-->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/vendors.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/materialize-stepper/materialize-stepper.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/select2/select2-materialize.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/opentip/opentip.css\">\r\n    <!-- <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/footable/css/footable.min.css\"> -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/footable-3/css/footable.bootstrap.min.css\">\r\n    <!-- END: VENDOR CSS-->\r\n    <!-- BEGIN: Page Level CSS-->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/materialize.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/style.css?v=1.1\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https: