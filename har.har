                    $('.tabs').tabs('select',\"tab_users\");\n                }else {\n                    $('.tabs').tabs('select',hash);\n                }\n                var secondHashIndex = hash.indexOf(\"#\");\n                if (secondHashIndex !== -1) {\n                    // Extract the substring after the single #\n                    var element_id = hash.substring(secondHashIndex + 1);\n                    // Use the shift_id as needed\n                    //$(\"#\"+element_id).delay( 400 ).animate({\"background-color\": '#ffca28'}, 500).delay( 2500 ).animate({\"background-color\": '#ffffff'}, 1500);\n                    flashElement(\"#\"+element_id, 5);\n                }\n            }\n\n            $('.foo-table-shifts').footable({\n                \"cascade\": true,\n                \"paging\": {\n                    \"enabled\": true\n                },\n                'columns': [\n                    \n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                ]\n            });\n            // $('.foo-table-shift-application_shifts').footable({\n            //     \"cascade\": true,\n            //     \"paging\": {\n            //         \"enabled\": true\n            //     },\n            //     'columns': [\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { },\n            //         { 'breakpoints': 'xs sm' },\n            //     ],\n            //     \"on\": {\n            //         \"postdraw.ft.table\": function(e, ft) {\n                        \n            //             ft.$el.find('[colspan!=\"\"][colspan]').each(function(index, element) {\n     