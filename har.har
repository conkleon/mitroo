{\n                if (hash.startsWith(\"tab_shifts\")){\n                    $('.tabs').tabs('select',\"tab_shifts\");\n                }else if (hash.startsWith(\"tab_users\")){\n                    $('.tabs').tabs('select',\"tab_users\");\n                }else {\n                    $('.tabs').tabs('select',hash);\n                }\n                var secondHashIndex = hash.indexOf(\"#\");\n                if (secondHashIndex !== -1) {\n                    // Extract the substring after the single #\n                    var element_id = hash.substring(secondHashIndex + 1);\n                    // Use the shift_id as needed\n                    //$(\"#\"+element_id).delay( 400 ).animate({\"background-color\": '#ffca28'}, 500).delay( 2500 ).animate({\"background-color\": '#ffffff'}, 1500);\n                    flashElement(\"#\"+element_id, 5);\n                }\n            }\n\n            $('.foo-table-shifts').footable({\n                \"cascade\": true,\n                \"paging\": {\n                    \"enabled\": true\n                },\n                'columns': [\n                    \n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                ]\n            });\n            // $('.foo-table-shift-application_shifts').footable({\n            //     \"cascade\": true,\n            //     \"paging\": {\n            //         \"enabled\": true\n            //     },\n            //     'columns': [\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { },\n            //         { 'breakpoints': 'xs sm' },\n            //     ],\n            //     \"on\": {\n            //         \"postdraw.ft.table\": function(e, ft) {\n                        \n            //             ft.$el.find('[colspan!=\"\"][colspan]').each(function(index, element) {\n            //                 var colspan = $(element).attr('colspan');\n            //                 $(element).nextAll('td:empty').slice(0, colspan).remove();\n            //             });\n            //         },\n            //         \"ready.ft.table\": function(e, ft) {//CAUTION: THIS IS REQUIRED IF TABLE HAS SUBMENUS OR ACTIONS!!!!!!!!!!!\n            //             $(\".dropdown-trigger-autowidth\").dropdown({constrainWidth: false, alignment: \"left\" });\n            //         }\n            //     }\n            // }); \n            \n            $('.foo-table-notes').footable({\n                \"cascade\": true,\n                \"paging\": {\n                    \"enabled\": true\n                },\n                'columns': [\n                    { 'breakpoints': 'xs sm'},\n                    { 'breakpoints': 'xs sm'},\n                    { },\n                    { 'breakpoints': 'xs sm'},\n                ],\n                \"on\": {\n                    \"ready.ft.table\": function(e, ft) {//CAUTION: THIS IS REQUIRED IF TABLE HAS SUBMENUS OR ACTIONS!!!!!!!!!!!\n                        $(\".dropdown-trigger-autowidth\").dropdown({constrainWidth: false, alignment: \"left\" });\n                    }\n                }\n            });\n\n          \n            $(\"ul.tabs li.tab a\").on(\"click\", function(event){\n                //console.log($(this));\n                window.location.hash = $(this).attr('href');\n            });\n            \n            $('.onlynumbers').on('input', function() {\n                let value = $(this).val();\n                let numbers = value.replace(/[^0-9]/g, \"\");\n                $(this).val( numbers );\n            });\n            \n            \n        });//end document load\n     </script>\n    <!-- END: Footer-->\n<