il', prefixIcon: 'e-edit', id: 'AccountDetails' }],\r\n    //toolbar: ['ExcelExport','CsvExport'],\r\n    toolbar: ['Search'],\r\n    editSettings: { allowEditing: false, allowAdding: false, allowDeleting: false },\r\n    gridLines: 'Both',\r\n    allowResizing: true,\r\n    allowExcelExport: false,\r\n    allowPdfExport: false,\r\n    columns: [\r\n        //{ field: 'id', width: 50, headerText: 'ΚΩΔ.', type: 'number' },\r\n        { field: 'title', headerText: 'ΤΙΤΛΟΣ', type: 'string', template: '#mission_link' },        \r\n        { field: 'mission_status_id', headerText: 'ΚΑΤΑΣΤΑΣΗ', width: 90, textAlign: 'left',  type: 'string',template: '#mission_statuses'},\r\n        { field: 'start_date', headerText: 'ΕΝΑΡΞΗ', width: 100, type: 'string' },\r\n        { field: 'end_date', headerText: 'ΛΗΞΗ', width: 100, type: 'string' },\r\n        { field: 'admin_full_name', headerText: 'ΥΠΕΥΘΥΝΟΣ', textAlign: 'left',  type: 'string',template: '#admin_member_link'},\r\n        { field: 'location_text', headerText: 'ΤΟΠΟΘΕΣΙΑ', type: 'string' },\r\n    ],\r\n    allowPaging: true,\r\n    pageSettings: { pageSize: 20,  pageCount: 10 },\r\n    allowSorting: true,\r\n    allowFiltering: false,\r\n    dataBound: function(){\r\n       //grid.autoFitColumns(['memberCard', 'id'])\r\n       //grid.autoFitColumns()\r\n    },\r\n    filterSettings: { type:'Menu', \r\n        mode: 'OnEnter',\r\n        showFilterBarOperator: true,\r\n        operators: {\r\n            stringOperator: [\r\n                    { value: 'contains', text: 'Περιλαμβάνει' },\r\n                    { value: 'equal', text: 'Ίσο με' }\r\n                ]\r\n            }},\r\n});\r\n\r\ngrid.appendTo('#Grid');\r\n\r\nwindow.admin_member_link = function (e) {\r\n    //console.log(e);\r\n    if(e.admin_member_id>0){\r\n        var ret_val = '<a href=\"javascript:;\" class=\"action member_quick_view\" data-member_id=\"' + e.admin_member_id + '\" data-member_name=\"' + e.admin_full_name + '\" title=\"γρήγορη προβολή\" >' + e.admin_full_name + '</a>';\r\n    }else{\r\n        var ret_val = 'ΔΕΝ ΕΧΕΙ ΟΡΙΣΤΕΙ';\r\n    }\r\n    \r\n    \r\n    return ret_val;\r\n};\r\n\r\nwindow.mission_link = function (e) {\r\n    //console.log(e);\r\n    var ret_val = '';\r\n    var my_member_id = 42253;\r\n    if ( my_member_id == e.admin_member_id ){\r\n        ret_val = '<a href=\"https://mitroo.redcross.gr/index.php/member/mission/'+e.id+'\" class=\"btn btn-small smaller blue text-white\" title=\"Διαχειρίζεστε αυτήν την αποστολή\" >' + e.title + ' -  ΔΙΑΧΕΙΡΙΣΗ</a>';\r\n    }else{\r\n        ret_val = '<a href=\"https://mitroo.redcross.gr/index.php/member/mission/'+e.id+'\" class=\"\" title=\"προβολή αποστολής\" >#' + e.id + ' - ' + e.title + '</a>';\r\n    }\r\n    \r\n    return ret_val;\r\n};\r\n\r\nwindow.mission_statuses = function (e) {\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    switch(e.mission_status_id){\r\n        case \"1\":\r\n            span.innerHTML += ' <span class=\"task-cat yellow darken-2\">ΠΡΟΧΕΙΡΟ</span>';\r\n            break;\r\n        case \"2\":\r\n            span.innerHTML += ' <span class=\"task-cat green\">ΑΝΟΙΚΤΗ</span>';\r\n            break;        \r\n        case \"3\":\r\n            span.innerHTML += ' <span class=\"task-cat purple\">ΕΚΛΕΙΣΕ</span>';\r\n            break;        \r\n        case \"4\":\r\n            span.innerHTML += ' <span class=\"task-cat blue\">ΟΛΟΚΛΗΡΩΘΗΚΕ</span>';\r\n            break;        \r\n        case \"5\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΔΙΟΡΓΑΝΩΤΗ)</span>';\r\n            break;        \r\n        case \"6\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΜΗ ΣΥΜΜΕΤΟΧΗ)</span>';\r\n            break;        \r\n        case \"7\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΔΙΟΡΓΑΝΩΤΗ)</span>';\r\n            break;        \r\n        case \"8\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΑΠΟ ΤΜΗΜΑ/ΕΕΣ)</span>';\r\n            break;        \r\n        case \"9\":\r\n            span.innerHTML += ' <span class=\"task-cat black\">ΟΡΙΣΤΙΚΟΠΟΙΗΜΕΝΗ</span>';\r\n            break;        \r\n        default:\r\n        span.innerHTML = 'ΑΓΝΩΣΤΟ!!';\r\n    }\r\n\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\n\r\n</script>\r\n\r\n\r\n\r\n</body>\r\n</html>"
