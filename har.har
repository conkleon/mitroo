/mitroo.redcross.gr/index.php/dptadmin/companyapplications/preauth\"><i class=\"material-icons\">assignment</i><span class=\"menu-title\" >Προς ολοκλήρωση</span></a></li>\r\n\t\t\r\n        <li class=\"navigation-header\"><a class=\"navigation-header-text\">ΕΓΓΡΑΦΑ</a><i class=\"navigation-header-icon material-icons\">more_horiz</i></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan  \" href=\"https://mitroo.redcross.gr/index.php/dptadmin/documents\"><i class=\"material-icons\">attach_file</i><span class=\"menu-title\" >Λίστα Γενικών Εγγράφων</span></a></li>\r\n\r\n        <li class=\"navigation-menu-item\"><hr/></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan \" href=\"https://faq.redcross.gr/\" target=\"_blank\"><i class=\"material-icons\">import_contacts</i><span class=\"menu-title\" >Οδηγίες χρήσης</span></a></li>\r\n\r\n\t</ul>\r\n\t<div class=\"navigation-background\"></div><a class=\"sidenav-trigger btn-sidenav-toggle btn-floating btn-medium waves-effect waves-light hide-on-large-only\" href=\"#\" data-target=\"slide-out\"><i class=\"material-icons\">menu</i></a>\r\n</aside>\r\n    <!-- END: SideNav-->\r\n\r\n    <!-- BEGIN: Page Main-->\r\n    <div id=\"main\">\r\n        <div class=\"row\">\r\n            <nav>\r\n                <div class=\"nav-wrapper\">\r\n                  <div class=\"col s12\">Εθελοντές - Τμήμα ΠΑΤΡΑ                  </div>\r\n                </div>\r\n            </nav>\r\n            <div class=\"col s12\">\r\n                <div class=\"container\">\r\n                    <div class=\"section\">\r\n                        <div class=\"card\">\r\n                            <div class=\"card-content \">\r\n                                <i class=\"material-icons right\">info</i><em>Μπορείτε να κάνετε αναζήτηση με Αρ. Μητρώου, Όνομα, Επίθετο, Email, Κινητό</em>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"card\">\r\n                            <div class=\"card-content\">\r\n                                <div id=\"Grid\"></div>                                \r\n                            </div>\r\n                        </div>\r\n                    </div>                                        \r\n                </div>\r\n                <div class=\"content-overlay\"></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <!-- END: Page Main-->\r\n    <!-- BEGIN: Footer-->\r\n    <aside id=\"right-sidebar-nav\">\r\n\t<div id=\"slide-out-right\" class=\"slide-out-right-sidenav sidenav rightside-navigation\">\r\n\t\t<div class=\"row\">\r\n\t\t\t<div class=\"slide-out-right-title\">\r\n\t\t\t\t<div class=\"col s12 border-bottom-1 pb-0 pt-1\">\r\n\t\t\t\t\t<div class=\"row\">\r\n\t\t\t\t\t\t<div class=\"col s2 pr-0 center\">\r\n\t\t\t\t\t\t\t<i class=\"material-icons vertical-text-middle\"><a href=\"#\" class=\"sidenav-close\">clear</a></i>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"slide-out-right-body\">\r\n\t\t\t\t<div id=\"settings\" class=\"col s12\">\r\n\t\t\t\t\t<p class=\"setting-header mt-3 mb-2 ml-5 font-weight-900\"><span class=\"sidebar_title\"></span></p>\r\n\t\t\t\t\t<ul class=\"collection border-none\">\r\n\t\t\t\t\t\t<li class=\"collection-item border-none\">\r\n\t\t\t\t\t\t\t<div class=\"m-0\">\r\n\t\t\t\t\t\t\t\t<div class=\"sidebar_content\"></div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</li>\t\t\t\t\t\t\t\t\t\t\t\r\n\t\t\t\t\t</ul>\t\t\t\t\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t\r\n</aside>\r\n<!-- END RIGHT SIDEBAR NAV --><footer class=\"page-footer footer footer-static footer-light navbar-border navbar-shadow\">\r\n\t <div class=\"footer-copyright\">\r\n\t\t <div class=\"container\">         \r\n            <!-- <small class=\"\"></small> -->\r\n            <small class=\"\"><a href=\"https://mitroo.redcross.gr/index.php/terms\">Όροι χρήσης πλατφόρμας</a></small>&nbsp;&nbsp;|&nbsp;&nbsp;<small class=\"\"><a target=\"_blank\" href=\"https://faq.redcross.gr/\">Οδηγίες χρήσης</a></small>\r\n            <span class=\"right hide-on-small-only\">Copyright © 2024 ΕΛΛΗΝΙΚΟΣ ΕΡΥΘΡΟΣ ΣΤΑΥΡΟΣ - A project by <a target=\"_blank\" href = \"https://nevma.gr\">Nevma</a></span></div>\r\n\t </div>\r\n </footer>\r\n\r\n <!-- END: Footer-->\r\n <!-- BEGIN VENDOR JS-->\r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/vendors.min.js\"></script>\r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/popper.min.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/bootstrap-4.3.1/js/bootstrap.bundle.min.js\"></script>\r\n <!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/bootstrap-5.3.2/js/bootstrap.bundle.min.js\"></script> -->\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/bootbox/bootbox.all.min.js\"></script>\r\n \r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/jquery-validation/jquery.validate.min.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/jquery-validation/additional-methods.min.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/jquery-validation/localization/messages_el.min.js\"></script>\r\n \r\n \r\n  <!-- BEGIN PAGE VENDOR JS-->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/loadingoverlay.min.js\"></script>\r\n<!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/sweetalert/sweetalert2.min.js\"></script> -->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/sweetalert/sweetalert2.all.min.js\"></script>\r\n<!--<script src=\"https://mitroo.redcross.gr/app-assets/vendors/noUiSlider/nouislider.js\"></script>-->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/scripts/form-elements.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.paginate.js\"></script>\r\n\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/select2/select2.full.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/opentip/opentip-jquery.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/flatpickr/flatpickr.js\"></script>\r\n\r\n<!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable/js/footable.all.min.js\"></script> -->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable-3/js/footable.min.js\"></script>\r\n\r\n\r\n<!-- END PAGE VENDOR JS-->\r\n <!-- BEGIN THEME  JS-->\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/plugins.js?t=1778608302\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/search.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.color-2.2.0.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/custom-script.js?t=1778608302\"></script>\r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/ocp-ajax-dpt-admin.js?t=1778608302\"></script>\t \r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/idle.js\"></script> \r\n \r\n  <!-- END THEME  JS-->\r\n <!-- BEGIN PAGE LEVEL JS-->\r\n <!-- END PAGE LEVEL JS-->\r\n     <!-- END: Footer-->\r\n    <script id=\"statusDetail\" type=\"text/x-template\">\r\n    ${statusDetail(data)}\r\n</script>\r\n<script id=\"memberFullName\" type=\"text/x-template\">\r\n    ${memberFullName(data)}\r\n</script>\r\n<script id=\"year_hours_tep\" type=\"text/x-template\">\r\n    ${year_hours_tep(data)}\r\n</script>\r\n<script id=\"year_hours_other\" type=\"text/x-template\">\r\n    ${year_hours_other(data)}\r\n</script>\r\n<script id=\"memberCard\" type=\"text/x-template\">\r\n    ${memberCard(data)}\r\n</script>\r\n<script type=\"text/javascript\">\r\nvar data = new ej.data.DataManager({\r\n    url: 'https://mitroo.redcross.gr/index.php/ajaxmember/grid_get_volunteers/',\r\n    adaptor: new ej.data.ODataV4Adaptor(),\r\n    crossDomain: true\r\n});\r\n\r\nvar grid = new ej.grids.Grid({\r\n    dataSource: data,\r\n    //toolbar: ['ExcelExport','CsvExport', { text: 'Details', tooltipText: 'View Detail', prefixIcon: 'e-edit', id: 'AccountDetails' }],\r\n    //toolbar: ['ExcelExport','CsvExport'],\r\n    toolbar: ['Search'],\r\n    editSettings: { allowEditing: false, allowAdding: false, allowDeleting: false },\r\n    gridLines: 'Both',\r\n    allowResizing: true,\r\n    allowExcelExport: false,\r\n    allowPdfExport: false,\r\n    toolbarClick: ToolbarClickHandler,\r\n    rowSelected: rowSelected,\r\n    commandClick: CommandClickHandler,\r\n    columns: [\r\n                { field: 'id', width: 50, headerText: 'ΚΩΔ.', type: 'number' },\r\n                { field: 'memberCard', headerText: 'ΣΤΟΙΧΕΙΑ', width:300, type: 'string', template: '#memberCard' },\r\n                { field: 'member_rank', headerText: 'ΒΑΘΜΟΣ', type: 'string' , filter: { type : 'CheckBox' }},\r\n                { field: 'mobile_phone', headerText: 'ΚΙΝΗΤΟ', width: 100, type: 'string' },\r\n                \r\n    ],\r\n    allowPaging: true,\r\n    pageSettings: { pageSize: 20,  pageCount: 10 },\r\n    allowSorting: true,\r\n    actionComplete: complete,\r\n    allowFiltering: false,\r\n    dataBound: function(){\r\n       //grid.autoFitColumns(['memberCard', 'id'])\r\n       //grid.autoFitColumns()\r\n    },\r\n    filterSettings: { type:'Menu', \r\n        mode: 'OnEnter',\r\n        showFilterBarOperator: true,\r\n        operators: {\r\n            stringOperator: [\r\n                    { value: 'contains', text: 'Περιλαμβάνει' },\r\n                    { value: 'equal', text: 'Ίσο με' }\r\n                ]\r\n            }},\r\n});\r\n\r\ngrid.appendTo('#Grid');\r\n\r\nfunction rowSelected(args) {\r\n    //console.log(args);    \r\n}\r\nfunction CommandClickHandler(args){//row button click\r\n    if(args.commandColumn.type==\"Edit\"){\r\n        console.log(args.rowData.p_account_id);\r\n        window.location.href = \"https://mitroo.redcross.gr/index.php/volunteers/detail/\"+args.rowData.id;\r\n    }\r\n    \r\n};\r\n\r\nfunction ToolbarClickHandler(args){\r\n    var gridObj = document.getElementById(\"Grid\").ej2_instances[0];\r\n    //grid.excelExport();\r\n    console.log(args.item.id);\r\n    console.log(gridObj);\r\n    if (args.item.id === 'Click') {\r\n        alert(\"Custom toolbar click...\");\r\n    }\r\n    if (args.item.id === 'Grid_excelexport') {\r\n        console.log('excel export..');        \r\n        gridObj.excelExport();        \r\n    }\r\n    if (args.item.id === 'Grid_csvexport') {\r\n        console.log('csv export..');        \r\n        gridObj.csvExport();        \r\n    }    \r\n    // Create grid object.\r\n    //var gridObj = $(\"#Grid\").data(\"Grid\");\r\n    //// Gets current view data of grid control\r\n    //dt = gridObj.getCurrentViewData();\r\n    //console.log(dt);\r\n};\r\nfunction complete(args) {\r\n    //console.log(args);\r\n    //if (args.requestType === \"filterchoicerequest\") {\r\n    //    if (args.filterModel.options.field === \"Trustworthiness\" || args.filterModel.options.field === \"Rating\" || args.filterModel.options.field === \"Status\") {\r\n    //        var span = args.filterModel.dialogObj.element.querySelectorAll('.e-selectall')[0];\r\n    //        if(!ej.base.isNullOrUndefined(span)) {\r\n    //            ej.base.closest(span, '.e-ftrchk').classList.add(\"e-hide\");\r\n    //        }\r\n    //    }\r\n    //}\r\n}\r\n\r\nwindow.statusDetail = function (e) {\r\n    //console.log(e);\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    span.innerHTML = \"\";\r\n\r\n    if (e.member_status == \"1\") {\r\n        span.innerHTML += ' <span class=\"task-cat green\">ΕΝΕΡΓΟΣ</span>';\r\n    }else{\r\n        span.innerHTML += ' <span class=\"task-cat red\">ΑΝΕΝΕΡΓΟΣ</span>';\r\n    }\r\n    \r\n    div.className = '';\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\nwindow.memberCard = function (e) {\r\n    //console.log(e);\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    // var div = document.createElement('div');\r\n    // var span;        \r\n    // span = document.createElement('span');\r\n    // span.innerHTML = e.last_name + ' ' + e.first_name;\r\n    // div.className = '';\r\n    \r\n    // div.appendChild(span);\r\n    var full_name = e.last_name + ' ' + e.first_name;\r\n    var profile_photo = e.profile_photo;\r\n    console.log(e.profile_photo);\r\n    if(profile_photo == \"\" || profile_photo == null){\r\n        profile_photo = \"no-image.png\";\r\n    }\r\n    var ret_val = '<div class=\"display-flex mb-3 syncfusion-grid\">'\r\n                    +'<div class=\"icon-avatar large mr-3\">'\r\n                    +'<img src=\"https://mitroo.redcross.gr/upload/members/'+ profile_photo + '\" alt=\"avatar\" class=\"rounded-circle\">'\r\n                    + '</div>'\r\n                    +'<div class=\"d-flex justify-content-between flex-grow-1\">'\r\n                        + '<div class=\"ml-1\">'\r\n                        + '    <p class=\"mb-0 mt-0 line-thin\"><a href=\"javascript:;\" class=\"action member_quick_view\" data-member_id=\"' + e.id + '\" data-member_name=\"' + full_name + '\" title=\"γρήγορη προβολή\" >' + full_name + '</a></p>' \r\n                        + '    <p class=\"mb-1 mt-0 line-thin\">' + e.registration_code + '</p> '\r\n                        + '    <p class=\"mb-0 mt-3\"> ';\r\n        // if(e.flag_pharmacy == 1){\r\n        //     ret_val += '<img src=\"https://mitroo.redcross.gr/app-assets/images/icon/flag_pharmacy.png\" alt=\"Αιμοδότης\" data-ot=\"\" class=\"flag-status-icon\"/>';\r\n        // }\r\n        // if(e.flag_blood_donor == 1){\r\n        //     ret_val += '<img src=\"https://mitroo.redcross.gr/app-assets/images/icon/flag_blood_donor.png\" alt=\"Φέρει φαρμακείο\" data-ot=\"Φέρει φαρμακείο\" class=\"flag-status-icon\"/>';\r\n        // }\r\n        // if(e.flag_radio == 1){\r\n        //     ret_val += '<img src=\"https://mitroo.redcross.gr/app-assets/images/icon/flag_radio.png\" alt=\"Ραδιοερασιτέχνης\" data-ot=\"Ραδιοερασιτέχνης\" class=\"flag-status-icon\"/>';\r\n        // }\r\n        // if(e.flag_driver == 1){\r\n        //     ret_val += '<img src=\"https://mitroo.redcross.gr/app-assets/images/icon/flag_driver.png\" alt=\"Οδηγός\" data-ot=\"Οδηγός\" class=\"flag-status-icon\"/>';\r\n        // }\r\n        if(e.member_status == 1){\r\n            ret_val += '<span class=\"task-cat green flag-status-task-cat\">ΕΝΕΡΓΟΣ</span>';\r\n        }else{\r\n            ret_val += '<span class=\"task-cat red flag-status-task-cat\">ΑΝΕΝΕΡΓΟΣ</span>';\r\n        }\r\n        if(e.rank_id == 22){\r\n            ret_val += '<span class=\"task-cat purple flag-status-task-cat ml-2\">ΔΟΚΙΜΟΣ/Η</span>';        \r\n        }\r\n        ret_val += '</p>'\r\n                + '</div>'\r\n                + '</div>'\r\n                + '</div>';\r\n    return ret_val;\r\n};\r\n\r\nwindow.memberFullName = function (e) {\r\n    //console.log(e);\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    span.innerHTML = e.last_name + ' ' + e.first_name;\r\n    div.className = '';\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\nwindow.year_hours_tep = function (e) {\r\n    //console.log(e);\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    if(e.year_hours_tep <30){\r\n        span.innerHTML += ' <span class=\"task-cat red\">' + e.year_hours_tep +'/100</span>';\r\n    }else if(e.year_hours_tep >=30 && e.year_hours_tep <70){\r\n        span.innerHTML += ' <span class=\"task-cat orange\">' + e.year_hours_tep +'/100</span>';\r\n    }else if(e.year_hours_tep >=70 && e.year_hours_tep <100){\r\n        span.innerHTML += ' <span class=\"task-cat blue\">' + e.year_hours_tep +'/100</span>';\r\n    } else{//over 100\r\n        span.innerHTML += ' <span class=\"task-cat green\">' + e.year_hours_tep +'/100</span>';\r\n    }\r\n    div.className = 'text-center';\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\nwindow.year_hours_other = function (e) {\r\n    //console.log(e);\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    var minimum_hours_per_year = 0;\r\n    if(e.rank_id == 22){//ΔΟΚΙΜΟΣ/Η\r\n        minimum_hours_per_year = 150;\r\n    }else{\r\n        minimum_hours_per_year = 100;\r\n    }\r\n    var hours_percent = e.year_hours_sanitary * 100 / minimum_hours_per_year;\r\n    if(hours_percent <30){\r\n        span.innerHTML += ' <span class=\"task-cat red\">' + e.year_hours_sanitary +'/' + minimum_hours_per_year + '</span>';\r\n    }else if(hours_percent >=30 && hours_percent <70){\r\n        span.innerHTML += ' <span class=\"task-cat orange\">' + e.year_hours_sanitary +'/' + minimum_hours_per_year + '</span>';\r\n    }else{\r\n        span.innerHTML += ' <span class=\"task-cat green\">' + e.year_hours_sanitary +'/' + minimum_hours_per_year + '</span>';\r\n    }\r\n    \r\n    div.className = 'text-center';\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\n</script>\r\n\r\n\r\n\r\n</body>\r\n</html>"
