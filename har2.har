jquery-validation/jquery.validate.min.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/jquery-validation/additional-methods.min.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/vendors/jquery-validation/localization/messages_el.min.js\"></script>\r\n \r\n \r\n  <!-- BEGIN PAGE VENDOR JS-->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/loadingoverlay.min.js\"></script>\r\n<!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/sweetalert/sweetalert2.min.js\"></script> -->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/sweetalert/sweetalert2.all.min.js\"></script>\r\n<!--<script src=\"https://mitroo.redcross.gr/app-assets/vendors/noUiSlider/nouislider.js\"></script>-->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/scripts/form-elements.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.paginate.js\"></script>\r\n\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/select2/select2.full.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/opentip/opentip-jquery.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/flatpickr/flatpickr.js\"></script>\r\n\r\n<!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable/js/footable.all.min.js\"></script> -->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable-3/js/footable.min.js\"></script>\r\n\r\n\r\n<!-- END PAGE VENDOR JS-->\r\n <!-- BEGIN THEME  JS-->\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/plugins.js?t=1779367547\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/search.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.color-2.2.0.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/custom-script.js?t=1779367547\"></script>\r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/ocp-ajax-dpt-admin.js?t=1779367547\"></script>\t \r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/idle.js\"></script> \r\n \r\n  <!-- END THEME  JS-->\r\n <!-- BEGIN PAGE LEVEL JS-->\r\n <!-- END PAGE LEVEL JS-->\r\n      \n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/dropify/css/dropify.min.css\">\n    <script src=\"https://mitroo.redcross.gr/app-assets/vendors/dropify/js/dropify.min.js\"></script> \n     <script>\n        $(function () {\n\n            function flashElement(element, times) {\n                // Get the top offset of the element\n                var topOffset = $(element).offset().top;\n\n                // Scroll to the element, then start the flashing animation\n                $('html, body').animate({\n                    scrollTop: topOffset-100\n                }, 200).promise().done(function() {\n                    var count = 0;\n                    var intervalId = setInterval(function() {\n                        $(element).toggleClass(\"flash\");\n                        count++;\n                        if (count === times * 2) {\n                            clearInterval(intervalId);\n                            $(element).removeClass(\"flash\"); // Ensure the element is not left with the flashing class\n                        }\n                    }, 200);\n                });\n            }\n\n            var hash =  window.location.hash.substr(1);\n            //console.log(\"hash:\"+hash);\n            if (hash.startsWith(\"tab_\")){\n                if (hash.startsWith(\"tab_shifts\")){\n                    $('.tabs').tabs('select',\"tab_shifts\");\n                }else if (hash.startsWith(\"tab_users\")){\n                    $('.tabs').tabs('select',\"tab_users\");\n                }else {\n                    $('.tabs').tabs('select',hash);\n                }\n                var secondHashIndex = hash.indexOf(\"#\");\n                if (secondHashIndex !== -1) {\n                    // Extract the substring after the single #\n                    var element_id = hash.substring(secondHashIndex + 1);\n                    // Use the shift_id as needed\n                    //$(\"#\"+element_id).delay( 400 ).animate({\"background-color\": '#ffca28'}, 500).delay( 2500 ).animate({\"background-color\": '#ffffff'}, 1500);\n                    flashElement(\"#\"+element_id, 5);\n                }\n            }\n\n            $('.foo-table-shifts').footable({\n                \"cascade\": true,\n                \"paging\": {\n                    \"enabled\": true\n                },\n                'columns': [\n                    \n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { 'breakpoints': 'xs sm' },\n                    { },\n                ]\n            });\n            // $('.foo-table-shift-application_shifts').footable({\n            //     \"cascade\": true,\n            //     \"paging\": {\n            //         \"enabled\": true\n            //     },\n            //     'columns': [\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { 'breakpoints': 'xs sm' },\n            //         { },\n            //         { 'breakpoints': 'xs sm' },\n            //     ],\n            //     \"on\": {\n            //         \"postdraw.ft.table\": function(e, ft) {\n                        \n            //             ft.$el.find('[colspan!=\"\"][colspan]').each(function(index, element) {\n            //                 var colspan = $(element).attr('colspan');\n            //                 $(element).nextAll('td:empty').slice(0, colspan).remove();\n            //             });\n            //         },\n            //         \"ready.ft.table\": function(e, ft) {//CAUTION: THIS IS REQUIRED IF TABLE HAS SUBMENUS OR ACTIONS!!!!!!!!!!!\n            //             $(\".dropdown-trigger-autowidth\").dropdown({constrainWidth: false, alignment: \"left\" });\n            //         }\n            //     }\n            // }); \n            \n            $('.foo-table-notes').footable({\n                \"cascade\": true,\n                \"paging\": {\n                    \"enabled\": true\n                },\n                'columns': [\n                    { 'breakpoints': 'xs sm'},\n                    { 'breakpoints': 'xs sm'},\n                    { },\n                    { 'breakpoints': 'xs sm'},\n                ],\n                \"on\": {\n                    \"ready.ft.table\": function(e, ft) {//CAUTION: THIS IS REQUIRED IF TABLE HAS SUBMENUS OR ACTIONS!!!!!!!!!!!\n                        $(\".dropdown-trigger-autowidth\").dropdown({constrainWidth: false, alignment: \"left\" });\n                    }\n                }\n            });\n\n          \n            $(\"ul.tabs li.tab a\").on(\"click\", function(event){\n                //console.log($(this));\n                window.location.hash = $(this).attr('href');\n            });\n            \n            $('.onlynumbers').on('input', function() {\n                let value = $(this).val();\n                let numbers = value.replace(/[^0-9]/g, \"\");\n                $(this).val( numbers );\n            });\n            \n            \n        });//end document load\n     </script>\n    <!-- END: Footer-->\n</body>\n</html>"
