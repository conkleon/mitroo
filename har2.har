form-elements.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.paginate.js\"></script>\r\n\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/select2/select2.full.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/opentip/opentip-jquery.min.js\"></script>\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/flatpickr/flatpickr.js\"></script>\r\n\r\n<!-- <script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable/js/footable.all.min.js\"></script> -->\r\n<script src=\"https://mitroo.redcross.gr/app-assets/vendors/footable-3/js/footable.min.js\"></script>\r\n\r\n\r\n<!-- END PAGE VENDOR JS-->\r\n <!-- BEGIN THEME  JS-->\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/plugins.js?t=1779367221\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/search.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/jquery.color-2.2.0.js\"></script>\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/custom-script.js?t=1779367221\"></script>\r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/ocp-ajax-dpt-admin.js?t=1779367221\"></script>\t \r\n\r\n <script src=\"https://mitroo.redcross.gr/app-assets/js/custom/idle.js\"></script> \r\n \r\n  <!-- END THEME  JS-->\r\n <!-- BEGIN PAGE LEVEL JS-->\r\n <!-- END PAGE LEVEL JS-->\r\n     <!-- END: Footer-->\r\n            \r\n    <script id=\"active\" type=\"text/x-template\">\r\n    ${active(data)}\r\n</script>\r\n<script id=\"mission_types\" type=\"text/x-template\">\r\n    ${mission_types(data)}\r\n</script>\r\n<script id=\"mission_statuses\" type=\"text/x-template\">\r\n    ${mission_statuses(data)}\r\n</script>\r\n<script id=\"shiftStatus\" type=\"text/x-template\">\r\n    ${shiftStatus(data)}\r\n</script>\r\n<script id=\"mission_link\" type=\"text/x-template\">\r\n    ${mission_link(data)}\r\n</script>\r\n\r\n\r\n<script type=\"text/javascript\">\r\nvar data = new ej.data.DataManager({\r\n    url: 'https://mitroo.redcross.gr/index.php/ajaxdptadmin/GridGetMissions/open',\r\n    adaptor: new ej.data.ODataV4Adaptor(),\r\n    crossDomain: true\r\n});\r\n\r\nvar grid = new ej.grids.Grid({\r\n    dataSource: data,\r\n    //toolbar: ['ExcelExport','CsvExport', { text: 'Details', tooltipText: 'View Detail', prefixIcon: 'e-edit', id: 'AccountDetails' }],\r\n    //toolbar: ['ExcelExport','CsvExport'],\r\n    toolbar: ['ExcelExport', 'CsvExport','Search'],\r\n    editSettings: { allowEditing: false, allowAdding: false, allowDeleting: false },\r\n    gridLines: 'Both',\r\n    allowResizing: true,\r\n    allowExcelExport: true,\r\n    allowPdfExport: true,\r\n    toolbarClick: ToolbarClickHandler,\r\n    rowSelected: rowSelected,\r\n    commandClick: CommandClickHandler,\r\n    columns: [\r\n                { field: 'id', width: 50, headerText: 'ΚΩΔ.', type: 'number' },\r\n                { field: 'title', headerText: 'ΤΙΤΛΟΣ', type: 'string', template: '#mission_link' },\r\n                //{ field: 'mission_type_id', headerText: 'ΤΥΠΟΣ', width: 90, textAlign: 'left',  type: 'string',template: '#mission_types'},\r\n                { field: 'mission_status_id', headerText: 'ΚΑΤΑΣΤΑΣΗ', width: 90, textAlign: 'left',  type: 'string',template: '#mission_statuses'},\r\n                //{ field: 'department_title', headerText: 'ΑΡΜ. ΤΜΗΜΑ', type: 'string' },\r\n                { field: 'start_date', headerText: 'ΕΝΑΡΞΗ', width: 100, type: 'date', format:'dd/MM/y', },\r\n                { field: 'end_date', headerText: 'ΛΗΞΗ', width: 100, type: 'date', format:'dd/MM/y', },\r\n                { field: 'location_text', headerText: 'ΤΟΠΟΘΕΣΙΑ', type: 'string' },\r\n                //{ field: 'mission_shift_count', headerText: 'ΑΡ. ΒΑΡΔΙΩΝ', type: 'string' },\r\n                { headerText: 'ΣΥΜΜΕΤΟΧΕΣ',  textAlign: 'center', template: '#shiftStatus'},\r\n                { field: 'admin_full_name', headerText: 'ΥΠΕΥΘΥΝΟΣ', textAlign: 'left',  type: 'string'},\r\n                // { field: 'last_login', headerText: 'Last Login', type: 'string' },\r\n                // { field: 'created_on', headerText: 'Created On', type: 'string' },                                                \r\n                // { field: 'active', headerText: 'Status', textAlign: 'Center',  type: 'number',template: '#active'},\r\n                //{ field: 'p_is_locked', headerText: 'Status', filter: { type: 'CheckBox', itemTemplate: '#StatusItemTemp' }, width: '150', template: \"#statusTemplate\" },\r\n                { headerText: 'Manage', width: 90,\r\n                    commands: [{ type: 'Edit', buttonOption: { iconCss: ' e-icons e-edit', cssClass: 'e-flat' } }]\r\n                }\r\n    ],\r\n    allowPaging: true,\r\n    pageSettings: { pageSize: 20,  pageCount: 10 },\r\n    allowSorting: true,\r\n    actionComplete: complete\r\n});\r\n\r\ngrid.appendTo('#Grid');\r\n\r\nfunction rowSelected(args) {\r\n    //console.log(args);    \r\n}\r\nfunction CommandClickHandler(args){//row button click\r\n    if(args.commandColumn.type==\"Edit\"){\r\n        console.log(args.rowData.p_account_id);\r\n        window.location.href = \"https://mitroo.redcross.gr/index.php/dptadmin/mission/\"+args.rowData.id;\r\n    }\r\n    \r\n};\r\n\r\nfunction ToolbarClickHandler(args){\r\n    var gridObj = document.getElementById(\"Grid\").ej2_instances[0];\r\n    //grid.excelExport();\r\n    console.log(args.item.id);\r\n    console.log(gridObj);\r\n    if (args.item.id === 'Click') {\r\n        alert(\"Custom toolbar click...\");\r\n    }\r\n    if (args.item.id === 'Grid_excelexport') {\r\n        console.log('excel export..');        \r\n        gridObj.excelExport();        \r\n    }\r\n    if (args.item.id === 'Grid_csvexport') {\r\n        console.log('csv export..');        \r\n        gridObj.csvExport();        \r\n    }    \r\n    // Create grid object.\r\n    //var gridObj = $(\"#Grid\").data(\"Grid\");\r\n    //// Gets current view data of grid control\r\n    //dt = gridObj.getCurrentViewData();\r\n    //console.log(dt);\r\n};\r\nfunction complete(args) {\r\n    //console.log(args);\r\n    //if (args.requestType === \"filterchoicerequest\") {\r\n    //    if (args.filterModel.options.field === \"Trustworthiness\" || args.filterModel.options.field === \"Rating\" || args.filterModel.options.field === \"Status\") {\r\n    //        var span = args.filterModel.dialogObj.element.querySelectorAll('.e-selectall')[0];\r\n    //        if(!ej.base.isNullOrUndefined(span)) {\r\n    //            ej.base.closest(span, '.e-ftrchk').classList.add(\"e-hide\");\r\n    //        }\r\n    //    }\r\n    //}\r\n}\r\n\r\nwindow.mission_link = function (e) {\r\n    //console.log(e);\r\n    var ret_val = '';\r\n    ret_val = '<a href=\"https://mitroo.redcross.gr/index.php/dptadmin/mission/'+e.id+'\" class=\"\" title=\"\" >' + e.title + '</a>';\r\n    return ret_val;\r\n};\r\n\r\nwindow.mission_statuses = function (e) {\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    switch(e.mission_status_id){\r\n        case \"1\":\r\n            span.innerHTML += ' <span class=\"task-cat yellow darken-2\">ΠΡΟΧΕΙΡΟ</span>';\r\n            break;\r\n        case \"2\":\r\n            span.innerHTML += ' <span class=\"task-cat green\">ΑΝΟΙΚΤΗ</span>';\r\n            break;        \r\n        case \"3\":\r\n            span.innerHTML += ' <span class=\"task-cat purple\">ΕΚΛΕΙΣΕ</span>';\r\n            break;        \r\n        case \"4\":\r\n            span.innerHTML += ' <span class=\"task-cat blue\">ΟΛΟΚΛΗΡΩΘΗΚΕ</span>';\r\n            break;        \r\n        case \"5\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΔΙΟΡΓΑΝΩΤΗ)</span>';\r\n            break;        \r\n        case \"6\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΜΗ ΣΥΜΜΕΤΟΧΗ)</span>';\r\n            break;        \r\n        case \"7\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΔΙΟΡΓΑΝΩΤΗ)</span>';\r\n            break;        \r\n        case \"8\":\r\n            span.innerHTML += ' <span class=\"task-cat red\">ΑΚΥΡΩΜΕΝΗ (ΑΠΟ ΤΜΗΜΑ/ΕΕΣ)</span>';\r\n            break;        \r\n        case \"9\":\r\n            span.innerHTML += ' <span class=\"task-cat black\">ΟΡΙΣΤΙΚΟΠΟΙΗΜΕΝΗ</span>';\r\n            break;        \r\n        default:\r\n        span.innerHTML = 'ΑΓΝΩΣΤΟ!!';\r\n    }\r\n\r\n    \r\n    div.appendChild(span);\r\n    return div.outerHTML;\r\n};\r\n\r\nwindow.shiftStatus = function (e) {\r\n    var grid = document.getElementById(\"Grid\").ej2_instances[0];\r\n    var div = document.createElement('div');\r\n    var span;        \r\n    span = document.createElement('span');\r\n    span.innerHTML = '<div class=\"text-center\" id=\"mission'+e.id+'\"><div class=\"preloader-wrapper active x-small\"><div class=\"spinner-layer spinner-red-only\"><div class=\"circle-clipper left\"><div class=\"circle\"></div></div><div class=\"gap-patch\"><div class=\"circle\"></div></div><div class=\"circle-clipper right\"><div class=\"circle\"></div></div></div></div></div>';\r\n    div.className = '';\r\n    div.appendChild(span);\r\n\r\n    var mission_id = e.id;\r\n    //console.log(\"mission:\"+mission_id);\r\n    $.ajax({\r\n        type: \"GET\",\r\n        hideOverlay: 'hideOverlay',\r\n        url: base_url+\"ajaxdptadmin/getMissionShiftsInfoForGrid/\"+mission_id\r\n     }).done(function(data) {\r\n        //console.log(data);\r\n        var result = $.parseJSON(data);\r\n        if(result.status == \"1\"){\r\n            $(\"#mission\"+result.data.mission_id).html('<span class=\"tooltip-task task-cat black pt-3 pr-3 pb-3 pl-3 mr-3\" data-ot=\"ΣΥΝΟΛΙΚΟΣ ΑΡΙΘΜΟΣ ΑΙΤΗΣΕΩΝ\">'+result.data.total_shifts+'</span> <span class=\"tooltip-task task-cat green pt-3 pr-3 pb-3 pl-3 mr-3\" data-ot=\"ΕΝΕΡΓΕΣ ΣΥΜΜΕΤΟΧΕΣ\">'+result.data.approved_shifts+'</span> <span class=\"tooltip-task task-cat blue pt-3 pr-3 pb-3 pl-3 mr-3\" data-ot=\"ΝΕΕΣ ΑΙΤΗΣΕΙΣ\">'+result.data.pending_shifts+'</span> <span class=\"tooltip-task task-cat red pt-3 pr-3 pb-3 pl-3 mr-3\"  data-ot=\"ΑΚΥΡΩΜΕΝΕΣ ΑΙΤΗΣΕΙΣ\">'+result.data.canceled_shifts+'</span>');\r\n\r\n            // Step 1: Select all elements with the class\r\n            var elements = document.querySelectorAll('.tooltip-task');\r\n\r\n            // Step 2: Loop through each element and apply OpenTip\r\n            elements.forEach(function(element) {\r\n                var tooltipText = element.getAttribute('data-ot');\r\n                new Opentip(element, tooltipText);\r\n            });\r\n\r\n        }else{\r\n            //$(limits_el).html('error loading limits!');\r\n            //$(\"#server\"+result.server_id).html('<span class=\"task-cat red\">ERROR</span>');\r\n        }\r\n        \r\n    });//end ajax\r\n\r\n    return div.outerHTML;\r\n};\r\n</script>\r\n<style>\r\n    .tooltip-task {\r\n    min-width: 40px;\r\n    display: inline-grid;\r\n    }\r\n</style>\r\n\r\n\r\n\r\n</body>\r\n</html>"
