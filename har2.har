          "mimeType" : "text/html; charset=UTF-8",
          "text" : "<!DOCTYPE html>\n<html class=\"loading\" lang=\"en\" data-textdirection=\"ltr\">\n<head>\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui\">\n    <title>Σύνδεση | Ε.Ε.Σ. CRM - Τ. ΣΑΜΑΡΕΙΤΩΝ</title>\n    <link rel=\"apple-touch-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\n    <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\n    <!-- BEGIN: VENDOR CSS-->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/vendors.min.css\">\n    <!-- END: VENDOR CSS-->\n    <!-- BEGIN: Page Level CSS-->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/materialize.css\">\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/style.css\">\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/pages/login.css\">\n    <!-- END: Page Level CSS-->\n    <!-- BEGIN: Custom CSS-->\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/custom/custom.css\">\n    <!-- END: Custom CSS-->\n     <style>\n        .input-field > label {\n           top: -30px;\n        }\n        .input-field .prefix{\n            top:-11px;\n        }\n     </style>\n</head>\n\n<body class=\"vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 1-column login-bg   blank-page blank-page\" data-open=\"click\" data-menu=\"vertical-dark-menu\" data-col=\"1-column\">\n    <div class=\"row\">\n        <div class=\"col s12\">\n            <div class=\"container\">\n                <div id=\"login-page\" class=\"row\">\n                    <div class=\"col s12 m6 l4 z-depth-4 card-panel border-radius-6 login-card bg-opacity-8\">\n                        <form action=\"https://mitroo.redcross.gr/index.php/auth/login\" method=\"post\" accept-charset=\"utf-8\">\n<input type=\"hidden\" name=\"rccrmtk\" value=\"a1730dbc8193f7ea613e296547f41871\" />                                                                                   \n\t\t\t\t\t\t\n                            <div class=\"row\">\n                                <div class=\"input-field col s12\">\n                                    <h5 class=\"ml-4\">Ε.Ε.Σ. CRM - Τ. ΣΑΜΑΡΕΙΤΩΝ - Σύνδεση</h5>\n                                </div>\n                            </div>\n                            <div class=\"row margin\">\n                                <div class=\"input-field col s12\">\n                                    <i class=\"material-icons prefix pt-2\">person_outline</i>\n                                    \n\t\t\t\t\t\t\t\t\t<input type=\"text\" id=\"identity\" autocomplete=\"off\" name=\"identity\" class=\"form-control\" value=\"\" />\n                                    <label for=\"identity\" class=\"center-align\">Email</label>\n                                </div>\n                            </div>\n                            <div class=\"row margin\">\n                                <div class=\"input-field col s12\">\n                                    <i class=\"material-icons prefix pt-2\">lock_outline</i>                                    \n\t\t\t\t\t\t\t\t\t\t<input type=\"password\" id=\"password\" autocomplete=\"off\" name=\"password\" class=\"form-control\" value=\"\"/>\n                                    <label for=\"password\">Κωδικός πρόσβασης</label>\n                                </div>\n                            </div>\n                            <div class=\"row\">\n                                <div class=\"col s12 m12 l12 ml-2 mt-1\">\n                                    <p>\n                                        <label>\n\t\t\t\t\t\t\t\t\t\t\t<input type=\"checkbox\" id=\"remember\" name=\"remember\" value=\"1\" />\n                                            <span>Να με θυμάσαι</span>\n                                        </label>\n                                    </p>\n                                </div>\n                            </div>\n                            <div class=\"row\">\n                                <div class=\"input-field col s12\">                                    \n\t\t\t\t\t\t\t\t\t<input class=\"btn waves-effect waves-light border-round green col s12 white-text \" type=\"submit\" name=\"submit\" id=\"submit\" value=\"Σύνδεση\" />\n                                </div>\n                            </div>\n\t\t\t\t\t\t\t<div class=\"row\">\n                                <div class=\"col s12\">                                    \n\t\t\t\t\t\t\t\t\t<div id=\"message\" class=\"medium-small materialize-red-text\"></div>\t\t\t\t\t\t\n                                </div>\n                            </div>\n                            <div class=\"row\">\n                                <div class=\"input-field col s6 m6 l6\">\n                                </div>\n                                <div class=\"input-field col s6 m6 l6\">\n                                    <p class=\"margin right-align medium-small\"><a href=\"https://mitroo.redcross.gr/index.php/auth/forgot_password\">Ξεχάσατε τον κωδικό σας;</a></p>\n                                </div>\n                            </div>\n                        </form>                    </div>\n                </div>\n            </div>\n            <div class=\"content-overlay\"></div>\n        </div>\n    </div>\n    <!-- END: div.row-->\n<!-- BEGIN: Footer-->\n<!-- END THEME  JS--><!-- END: Footer-->\n</body>\n</html>"
