          "mimeType" : "text/html; charset=UTF-8",
          "text" : "<!DOCTYPE html>\n<html class=\"loading\" lang=\"en\" data-textdirection=\"ltr\">\n<head>\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui\">\r\n    <title>Γρήγορη επισκόπηση - Ε.Ε.Σ. CRM - Τ. ΣΑΜΑΡΕΙΤΩΝ</title>\r\n    <link rel=\"apple-touch-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\r\n    <link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"https://mitroo.redcross.gr/app-assets/images/favicon/favicon.png\">\r\n    <!-- BEGIN: VENDOR CSS-->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/vendors.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/materialize-stepper/materialize-stepper.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/select2/select2-materialize.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/opentip/opentip.css\">\r\n    <!-- <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/footable/css/footable.min.css\"> -->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/footable-3/css/footable.bootstrap.min.css\">\r\n    <!-- END: VENDOR CSS-->\r\n    <!-- BEGIN: Page Level CSS-->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/materialize.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/themes/vertical-dark-menu-template/style.css?v=1.1\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/vendors/flatpickr/flatpickr.min.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/timeline.css\">\r\n    <!-- END: Page Level CSS-->\r\n    <!-- BEGIN: Custom CSS-->\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"https://mitroo.redcross.gr/app-assets/css/custom/custom.css?v=1.8\">\r\n    <!-- END: Custom CSS-->\r\n   \r\n   <!--BEGIN: SYNCFUSION GRID CODE-->\r\n    \r\n    <!-- Essential JS 2 Grid's dependent material theme -->\r\n    <!-- THESE BELLOW WILL BE LOADED LOCALLY FOR NOW -->\r\n    <!--<link href=\"http://cdn.syncfusion.com/ej2/ej2-base/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-buttons/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-popups/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-navigations/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-dropdowns/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-lists/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-inputs/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-calendars/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-splitbuttons/styles/material.css\" rel=\"stylesheet\">\r\n    <link href=\"http://cdn.syncfusion.com/ej2/ej2-grids/styles/material.css\" rel=\"stylesheet\">\r\n    <script src=\"http://cdn.syncfusion.com/ej2/dist/ej2.min.js\" type=\"text/javascript\"></script>-->\r\n    \r\n    \r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-base-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-buttons-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-popups-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-navigations-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-dropdowns-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-lists-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-inputs-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-calendars-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-splitbuttons-material.css\" rel=\"stylesheet\">\r\n    <link href=\"https://mitroo.redcross.gr/app-assets/cdn/ej2-grids-material.css\" rel=\"stylesheet\">\r\n    <script src=\"https://mitroo.redcross.gr/app-assets/cdn/ej2.min.js\" type=\"text/javascript\"></script>\r\n    \r\n    <!--END: SYNCFUSION GRID CODE-->\r\n   <!-- <script src=\"https://www.jsviews.com/download/jsrender.min.js\" type=\"text/javascript\"></script>-->\r\n   <script type=\"text/javascript\">\r\n      var base_url = 'https://mitroo.redcross.gr/';\r\n      function check_cookie_name(name) \r\n      {\r\n          var ret_val = '';\r\n          var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));\r\n          if (match) {\r\n            //console.log(match[2]);\r\n            ret_val =match[2];\r\n          }\r\n          return ret_val;\r\n     }\r\n     var csrfName = 'rccrmtk';\r\n     var csrfHash = check_cookie_name('rccrmck');\r\n   </script>\n</head>\n\n<body class=\"vertical-layout dashboard-page page-header-light vertical-menu-collapsible preload-transitions 2-columns   \" data-open=\"click\" data-menu=\"vertical-dark-menu\" data-col=\"2-columns\">\n\n    <!-- BEGIN: Header-->\n    <header class=\"page-topbar\" id=\"header\">\r\n\t<div class=\"navbar navbar-fixed\">\r\n\t\t<nav class=\"navbar-main no-shadow navbar-color nav-collapsible sideNav-lock navbar-light\">\r\n\t\t\t<div class=\"nav-wrapper\">\r\n                                <div class=\"header-search-wrapper hide-on-med-and-down\"><i class=\"material-icons\">search</i>\r\n\t\t\t\t\t<form class=\"top_search_form\">\t\t\t\t\t\t\r\n\t\t\t\t\t\t<input class=\"header-search-input z-depth-2\" type=\"text\" id=\"search\" name=\"search\" placeholder=\"ΑΝΑΖΗΤΗΣΗ ΕΘΕΛΟΝΤΗ (ΕΠΩΝΥΜΟ ή Α.Μ.)\" data-search=\"template-list\">\r\n\t\t\t\t\t\t<ul class=\"search-list collection display-none\"></ul>\r\n\t\t\t\t\t</form>\r\n\t\t\t\t</div>\r\n                \t\t\t\t<ul class=\"navbar-list right\">\r\n                    \r\n\r\n\t\t\t\t\t<li class=\"hide-on-med-and-down\"><a class=\"waves-effect waves-block waves-light toggle-fullscreen\" href=\"javascript:void(0);\"><i class=\"material-icons\">settings_overscan</i></a></li>\r\n\t\t\t\t\t<!--<li class=\"hide-on-large-only search-input-wrapper\"><a class=\"waves-effect waves-block waves-light search-button\" href=\"javascript:void(0);\"><i class=\"material-icons\">search</i></a></li>-->\r\n                    <li><a class=\"waves-effect waves-block waves-light notification-button\" href=\"javascript:;\" data-target=\"notifications-dropdown\"><i class=\"material-icons\">notifications_none<small class=\"notification-badge\">1873</small></i></a></li>                    \r\n\t\t\t\t\t<li><a class=\"waves-effect waves-block waves-light profile-button\" href=\"javascript:void(0);\" data-target=\"profile-dropdown\"><i class=\"material-icons\">person</i></a></li>\r\n\t\t\t\t\t<!--<li><a id=\"mybtn123\" class=\"waves-effect waves-block waves-light sidenav-trigger\" href=\"#\" data-target=\"slide-out-right\"><i class=\"material-icons\">format_indent_increase</i></a></li>-->\r\n\t\t\t\t\t<li><a class=\"waves-effect waves-block waves-light sidenav-trigger\" href=\"https://mitroo.redcross.gr/index.php/auth/logout\" title=\"Logout\"><i class=\"material-icons\">power_settings_new</i></a></li>\r\n\t\t\t\t</ul>  \r\n                <!-- notifications-dropdown-->\r\n                <ul class=\"dropdown-content\" id=\"notifications-dropdown\">\r\n    <li>\r\n        <h6><strong>ΕΙΔΟΠΟΙΗΣΕΙΣ</strong><span class=\"new badge\">1873</span></h6>\r\n                <small class=\"blue-text\">εμφανίζονται οι 5 πιο πρόσφατες</small>\r\n            </li>\r\n        <li class=\"divider\"></li>\r\n        <li><a class=\"black-text\" href=\"https://mitroo.redcross.gr/index.php/notifications/view/1643617\"><span class=\"material-icons icon-bg-circle green small\">important_devices</span> Νέα Αποστολή: RALLY ACROPOLIS    <span class=\"notification-subtitle green-text text-darken-3\">Η αποστολή είναι ανοικτή, μπορείτε να δείτε τις βάρδιες και να δηλώσετε συμμετοχή</span></a>\r\n    </li>\r\n    <li class=\"divider\"></li>\r\n        <li><a class=\"black-text\" href=\"https://mitroo.redcross.gr/index.php/notifications/view/1643378\"><span class=\"material-icons icon-bg-circle green small\">important_devices</span> Νέα Αποστολή: ΟΛΥΜΠΙΑΚΗ ΑΚΑΔΗΜΙΑ - ΣΥΝΟΔΟΣ ΝΕΩΝ    <span class=\"notification-subtitle green-text text-darken-3\">Η αποστολή είναι ανοικτή, μπορείτε να δείτε τις βάρδιες και να δηλώσετε συμμετοχή</span></a>\r\n    </li>\r\n    <li class=\"divider\"></li>\r\n        <li><a class=\"black-text\" href=\"https://mitroo.redcross.gr/index.php/notifications/view/1643140\"><span class=\"material-icons icon-bg-circle green small\">important_devices</span> Νέα Αποστολή: ΣΥΛΛΟΓΟΣ ΔΑΒΟΥΡΛΗ - ΑΓΩΝΕΣ ΠΟΔΟΣΦΑΙΡΟΥ ΕΡΓΑΖΟΜΕΝΩΝ    <span class=\"notification-subtitle green-text text-darken-3\">Η αποστολή είναι ανοικτή, μπορείτε να δείτε τις βάρδιες και να δηλώσετε συμμετοχή</span></a>\r\n    </li>\r\n    <li class=\"divider\"></li>\r\n        <li><a class=\"black-text\" href=\"https://mitroo.redcross.gr/index.php/notifications/view/1642902\"><span class=\"material-icons icon-bg-circle green small\">important_devices</span> Νέα Αποστολή: ΠΡΩΤΟΒΑΘΜΙΑ ΕΚΠΑΙΔΕΥΣΗ - ΘΕΑΤΡΙΚΗ ΟΜΑΔΑ    <span class=\"notification-subtitle green-text text-darken-3\">Η αποστολή είναι ανοικτή, μπορείτε να δείτε τις βάρδιες και να δηλώσετε συμμετοχή</span></a>\r\n    </li>\r\n    <li class=\"divider\"></li>\r\n        <li><a class=\"black-text\" href=\"https://mitroo.redcross.gr/index.php/notifications/view/1642664\"><span class=\"material-icons icon-bg-circle green small\">important_devices</span> Νέα Αποστολή: ΠΡΩΤΟΒΑΘΜΙΑ ΕΚΠΑΙΔΕΥΣΗ - ΧΟΡΕΥΤΙΚΑ    <span class=\"notification-subtitle green-text text-darken-3\">Η αποστολή είναι ανοικτή, μπορείτε να δείτε τις βάρδιες και να δηλώσετε συμμετοχή</span></a>\r\n    </li>\r\n    <li class=\"divider\"></li>\r\n        <li class=\"dropdown-menu-footer border-top p-2\">\r\n        <a href=\"https://mitroo.redcross.gr/index.php/notifications\" class=\"btn btn-primary d-flex pt-2 pb-1\">\r\n        Δες όλες τις ειδοποιήσεις\r\n        </a>\r\n    </li>\r\n    </ul>                       \r\n                <!-- <ul class=\"dropdown-content\" id=\"notifications-dropdown\">\r\n                    <li>\r\n                        <h6>ΕΙΔΟΠΟΙΗΣΕΙΣ<span class=\"new badge\">3</span></h6>\r\n                    </li>\r\n                    <li class=\"divider\"></li>\r\n                    <li><a class=\"black-text\" href=\"#!\"><span class=\"material-icons icon-bg-circle green small\">today</span> Πεμ 28-03-2024 10:00-12:00, ΚΑΘΑΡΙΣΜΟΣ</a>\r\n                        <time class=\"media-meta green-text text-darken-3\" datetime=\"2015-06-12T20:50:48+08:00\">Η συμμετοχή σου στη βάρδια εγκρίθηκε!</time>\r\n                    </li>\r\n                    <li><a class=\"black-text\" href=\"#!\"><span class=\"material-icons icon-bg-circle red small\">today</span> Πεμ 28-03-2024 10:00-12:00, ΚΑΘΑΡΙΣΜΟΣ</a>\r\n                        <time class=\"media-meta red-text\" datetime=\"2015-06-12T20:50:48+08:00\">Η συμμετοχή σου στη βάρδια ακυρώθηκε!</time>\r\n                    </li>\r\n                    <li><a class=\"black-text\" href=\"#!\"><span class=\"material-icons icon-bg-circle purple small\">access_time</span> Κέρδισες νέες ώρες</a>\r\n                        <time class=\"media-meta purple-text\" datetime=\"2015-06-12T20:50:48+08:00\">3 ώρες προστέθηκαν στο λογαριασμό σου!</time>\r\n                    </li>\r\n                    <li class=\"dropdown-menu-footer border-top p-2\">\r\n                        <a href=\"javascript:void(0);\" class=\"btn btn-primary d-flex pt-2 pb-1\">\r\n                        Δες όλες τις ειδοποιήσεις\r\n                        </a>\r\n                    </li>\r\n                </ul>                  -->\r\n\t\t\t\t<!-- profile-dropdown-->\r\n\t\t\t\t<ul class=\"dropdown-content\" id=\"profile-dropdown\">\r\n\t\t\t\t\t<li><a class=\"grey-text text-darken-1\" href=\"https://mitroo.redcross.gr/index.php/auth/profile\"><i class=\"material-icons\">person</i> Το προφίλ μου </a></li>\r\n\t\t\t\t\t<li><a class=\"grey-text text-darken-1\" href=\"https://mitroo.redcross.gr/index.php/auth/logout\"><i class=\"material-icons\">keyboard_tab</i> Αποσύνδεση</a></li>\r\n\t\t\t\t</ul>\r\n\t\t\t</div>\r\n\t\t\t<nav class=\"display-none search-sm_RENAMED\">\r\n\t\t\t\t<div class=\"nav-wrapper\">\r\n\t\t\t\t\t<form class=\"top_search_form\">\r\n\t\t\t\t\t\t<div class=\"input-field search-input-sm\">\r\n\t\t\t\t\t\t\t<input class=\"search-box-sm mb-0\" type=\"search\" required=\"\" id=\"search\" name=\"search\" data-search=\"template-list\">\r\n\t\t\t\t\t\t\t<label class=\"label-icon\" for=\"search\"><i class=\"material-icons search-sm-icon\">search</i></label><i class=\"material-icons search-sm-close\">close</i>\r\n\t\t\t\t\t\t\t<ul class=\"search-list collection search-list-sm display-none\"></ul>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</form>\r\n\t\t\t\t</div>\r\n\t\t\t</nav>\r\n\t\t</nav>\r\n\t</div>\r\n\r\n</header>\r\n    <!-- END: Header-->\n    <!-- BEGIN: SideNav-->\n    <aside class=\"sidenav-main nav-expanded nav-lock nav-collapsible sidenav-dark sidenav-active-rounded\">\r\n\t<div class=\"brand-sidebar no-shadow\">\r\n    <h1 class=\"logo-wrapper\">\r\n        <a class=\"brand-logo\" href=\"https://mitroo.redcross.gr/index.php/dptadmin/dashboard\">\r\n            <img class=\"hide-on-med-and-down \" src=\"https://mitroo.redcross.gr/app-assets/images/logo/materialize-logo.png\" alt=\"OCP\" />\r\n            <img class=\"show-on-medium-and-down hide-on-med-and-up\" src=\"https://mitroo.redcross.gr/app-assets/images/logo/materialize-logo-color.png\" alt=\"OCP\" />\r\n            <span class=\"logo-text hide-on-med-and-down\">Ε.Ε.Σ. CRM</span>\r\n        </a>\r\n        <a class=\"navbar-toggler\" href=\"#\"><i class=\"material-icons\">radio_button_checked</i></a>\r\n        <div class=\"sidebar-username\">ΧΡΙΣΤΟΠΟΥΛΟΣ ΚΩΝΣΤΑΝΤΙΝΟΣ ΚΛΕΩΝ<br/>[ADMIN ΑΠΟΣΤ.]          </div>\r\n    </h1>\r\n\t</div>\r\n\t<ul class=\"sidenav sidenav-collapsible leftside-navigation collapsible sidenav-fixed menu-shadow\" id=\"slide-out\" data-menu=\"menu-navigation\" data-collapsible=\"accordion\">\r\n\t\t\r\n        <li class=\"navigation-header\"><a class=\"navigation-header-text\">ΓΡΗΓΟΡΗ ΠΡΟΣΒΑΣΗ </a><i class=\"navigation-header-icon material-icons\">more_horiz</i></li>\r\n\t\t<li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan active\" href=\"https://mitroo.redcross.gr/index.php/dptadmin/dashboard\"><i class=\"material-icons\">content_paste</i><span class=\"menu-title\" >Γρήγορη επισκόπηση</span></a></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan \" href=\"https://mitroo.redcross.gr/index.php/dptadmin/quickmissions/open\"><i class=\"material-icons\">important_devices</i><span class=\"menu-title\" >Ανοικτές αποστολές</span></a></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan \" href=\"https://mitroo.redcross.gr/index.php/dptadmin/quickmissions/all\"><i class=\"material-icons\">important_devices</i><span class=\"menu-title\" >Όλες οι αποστολές</span></a></li>\r