.redcross.gr/index.php/dptadmin/companyapplications/new\"><i class=\"material-icons\">assignment</i><span class=\"menu-title\" >Νέες αιτήσεις</span></a></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan  \" href=\"https://mitroo.redcross.gr/index.php/dptadmin/companyapplications/preauth\"><i class=\"material-icons\">assignment</i><span class=\"menu-title\" >Προς ολοκλήρωση</span></a></li>\r\n\t\t\r\n        <li class=\"navigation-header\"><a class=\"navigation-header-text\">ΕΓΓΡΑΦΑ</a><i class=\"navigation-header-icon material-icons\">more_horiz</i></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan  \" href=\"https://mitroo.redcross.gr/index.php/dptadmin/documents\"><i class=\"material-icons\">attach_file</i><span class=\"menu-title\" >Λίστα Γενικών Εγγράφων</span></a></li>\r\n\r\n        <li class=\"navigation-menu-item\"><hr/></li>\r\n        <li class=\"navigation-menu-item\"><a class=\"waves-effect waves-cyan \" href=\"https://faq.redcross.gr/\" target=\"_blank\"><i class=\"material-icons\">import_contacts</i><span class=\"menu-title\" >Οδηγίες χρήσης</span></a></li>\r\n\r\n\t</ul>\r\n\t<div class=\"navigation-background\"></div><a class=\"sidenav-trigger btn-sidenav-toggle btn-floating btn-medium waves-effect waves-light hide-on-large-only\" href=\"#\" data-target=\"slide-out\"><i class=\"material-icons\">menu</i></a>\r\n</aside>\r\n    <!-- END: SideNav-->\n\n    <!-- BEGIN: Page Main-->\n    <div id=\"main\">        \n        <div class=\"row\">\n            <nav>\n                <div class=\"nav-wrapper\">\n                    <div class=\"col s12\">\n                        <a href=\"https://mitroo.redcross.gr/index.php/dptadmin/missions/open\" class=\"breadcrumb\">Αποστολές</a>\n                        <span class=\"breadcrumb\">Δημιουργία νέας αποστολής- Τμήμα ΠΑΤΡΑ</span>\n                        <ul class=\"right\">                    \n                            <li><a href=\"javascript:window.history.back();\"><i class=\"material-icons left\">keyboard_return</i>Επιστροφή</a></li>\n                        </ul>\n                    </div>\n                </div>\n            </nav>\n            <div class=\"col s12\">\n                <div class=\"container\">\n                    <div class=\"section\">\n                        <!--<div class=\"card\">\n                        <div class=\"card-content\">-->\n                        <!--work collections start-->                        \n                        <div class=\"ocp-info-card\">\n                            <div class=\"row\">\n                                <div class=\"col s12\">\n                                    <form action=\"https://mitroo.redcross.gr/index.php/dptadmin/newmission\" id=\"addnew\" method=\"post\" accept-charset=\"utf-8\">\n                                                                                                        <input type=\"hidden\" name=\"rccrmtk\" value=\"a1730dbc8193f7ea613e296547f41871\" />\n                                    <ul class=\"collection \">\n                                        <li class=\"collection-item avatar\">\n                                            <i class=\"material-icons cyan circle\">important_devices</i>\n                                            <h5 class=\"collection-header mt-1\">Βασικά στοιχεία αποστολής</h5>\n                                            <p>Συμπληρώστε τα παρακάτω πεδία για να δημιουργήσετε μία νέα αποστολή. Μετά την αποθήκευση των στοιχείων θα μπορέσετε να δημιουργήσετε τις σχετικές βάρδιες της αποστολής.</p>\n                                        </li>\n                                        <li class=\"collection-item\">\n                                            <div class=\"row mb-2 mt-1\">\n                                                <div class=\"input-field1 col l5 m6 s12\">\n                                                    <label for=\"title\" class=\"active\">Τίτλος αποστολής</label>\n                                                    <input type=\"text\" name=\"title\" value=\"\" id=\"title\" required=\"required\"  />\n                                                </div>\n                                                <div class=\"col l3 m6 s12\">\n                                                    \n                                                                                                        <select class=\"select2 browser-default\" id=\"mission_type_id\" name=\"mission_type_id\" >\n                                                        <option value=\"\" >Επιλέξτε τύπο αποστολής </option>\n                                                                                                                <option value=\"71\" >BLS “ΒΑΣΙΚΗ ΥΠΟΣΤΗΡΙΞΗ ΖΩΗΣ’’</option>\n                                                                                                                <option value=\"56\" >ΑΣΚΗΣΗ - ΕΚΠΑΙΔΕΥΣΗ ΠΡΟΛΗΨΗΣ</option>\n                                                                                                                <option value=\"57\" >ΕΘΕΛΟΝΤΙΚΗ ΔΡΑΣΤΗΡΙΟΤΗΤΑ</option>\n                                                                                                                <option value=\"36\" >ΕΚΠΑΙΔΕΥΣΗ Α΄ ΒΟΗΘΕΙΩΝ ΣΕ ΠΟΛΙΤΕΣ</option>\n                                                                                                                <option value=\"86\" >ΕΚΠΑΙΔΕΥΣΗ Α' ΒΟΗΘΕΙΕΣ ΓΙΑ ΣΚΥΛΟΥΣ</option>\n                                                                                                                <option value=\"33\" >ΕΚΠΑΙΔΕΥΣΗ ΔΟΚΙΜΩΝ ΣΑΜΑΡΕΙΤΩΝ</option>\n                                                                                                                <option value=\"83\" >ΕΚΠΑΙΔΕΥΣΗ ΕΝΕΡΓΟΠΟΙΗΣΗΣ ΑΝΕΝΕΡΓΩΝ ΕΘΕΛΟΝΤΩΝ</option>\n                                                                                                                <option value=\"60\" >ΔΡΑΣΤΗΡΙΟΤΗΤΑ ΝΑΥΑΓΟΣΩΣΤΙΚΗΣ ΚΑΛΥΨΗΣ</option>\n                                                                                                                <option value=\"85\" >Τ.Ε.Π. ΔΟΚΙΜΩΝ</option>\n                                                                                                                <option value=\"16\" >ΥΓΕΙΟΝΟΜΙΚΗ ΚΑΛΥΨΗ</option>\n                                                                                                                <option value=\"81\" >ΥΠΟΧΡΕΩΤΙΚΗ ΕΤΗΣΙΑ ΕΚΠΑΙΔΕΥΣΗ ΕΘΕΛΟΝΤΗ</option>\n                                                                                                            </select>\n                                                    <div class=\"input-field\">\n                                                    </div>\n                                                </div>\n                                                <div class=\"input-field1 col l2 m6 s12\">\n                                                    <label for=\"start_date\" class=\"active\">Έναρξη αποστολής</label>\n                                                    <input type=\"text\" name=\"start_date\" value=\"\" id=\"start_date\" required=\"required\" class=\"\"  />\n                                                </div>\n                                                 <div class=\"input-field1 col l2 m6 s12\">\n                                                    <label for=\"end_date\" class=\"active\">Λήξη αποστολής</label>   \n                                                    <input type=\"text\" name=\"end_date\" value=\"\" id=\"end_date\" required=\"required\" class=\"datepicker111\"  />\n                                                </div>\n                                            </div> \n                                            <div class=\"row\">\n                                                <div class=\"input-field1 col m6 s12\">\n                                                    <label for=\"location_text\" class=\"active\">Τοποθεσία</label>    \n                                                    <input type=\"text\" name=\"location_text\" value=\"\" id=\"location_text\" required=\"required\"  />\n                                                </div>                                                \n                                                <div class=\"input-field1 col m6 s12\">\n                                                    <label for=\"location_url\" class=\"active\">Χάρτης (Google maps URL)</label>\n                                                    <input type=\"text\" name=\"location_url\" value=\"\" id=\"location_url\"  />\n                                                </div>\n                                            </div>\n                                        </li>\n                                        <li class=\"collection-item\">\n                                            <div class=\"row\">\n                                                <div class=\" col m6 s12\">\n                                                    <label for=\"role\">Υπεύθυνος αποστολής</label>\n                                                                                                        <select class=\"select2 browser-default\" id=\"admin_member_id\" name=\"admin_member_id\">\n                                                        <option value=\"\" disabled selected>Επιλέξτε υπεύθυνο</option>\n                                                                                                                <option value=\"43943\" >ΑΓΟΡΓΙΑΝΙΤΗ ΗΛΕΚΤΡΑ</option>\n                                                                                                                <option value=\"43960\" >ΑΘΑΝΑΣΙΟΥ ΧΑΡΙΚΛΕΙΑ</option>\n                                                                                                                <option value=\"43942\" >ΑΘΑΝΑΣΟΠΟΥΛΟΥ ΕΙΡΗΝΗ</option>\n                                                                                                                <option value=\"43928\" >ΑΛΕΞΑΚΟΣ ΛΟΥΚΑΣ</option>\n                                                                                                                <option value=\"43919\" >ΑΜΑΡΑΝΤΟΣ ΒΑΣΙΛΕΙΟΣ</option>\n                                                                                                                <option value=\"43225\" >ΑΜΠΟΥΛΕΡΗ ΑΝΤΩΝΙΑ</option>\n                                                                                                                <option value=\"42257\" >ΑΝΑΣΤΑΣΙΟΥ ΝΙΚΗ</option>\n                                                                                                                <option value=\"41972\" >ΑΝΑΣΤΑΣΟΠΟΥΛΟΣ ΑΛΕΞΑΝΔΡΟΣ</option>\n                                                                                                                <option value=\"5700\" >ΑΝΔΡΙΚΟΠΟΥΛΟΥ ΓΑΡΥΦΑΛΛΙΑ</option>\n                                                                                                                <option value=\"38585\" >ΑΝΔΡΙΚΟΠΟΥΛΟΥ ΚΩΝΣΤΑΝΤΙΝΑ</option>\n                                                                                                                <option value=\"43949\" >ΑΝΔΡΙΟΠΟΥΛΟΥ ΔΗΜΗΤΡΑ ΑΘΑΝΑΣΙΑ</option>\n                                                                                                                <option value=\"43226\" >ΑΝΕΣΤΙΔΟΥ ΑΝΑΣΤΑΣΙΑ - ΙΩΑΝΝΑ</option>\n                                                                                                                <option value=\"42261\" >ΑΡΑΓΙΑΝΝΗ ΕΛΕΝΗ</option>\n                                                                                                                <option value=\"42262\" >ΑΡΒΑΝΙΤΗ ΜΑΡΙΑ</option>\n                                                                                                                <option value=\"43966\" >ΑΣΗΜΑΚΗ ΜΑΡΘΑ ΜΑΡΙ