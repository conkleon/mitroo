# ─────────────────────────────────────────────
# Mitroo – shared environment variables
# Copy this to .env and fill in real values.
# ─────────────────────────────────────────────

NODE_ENV=development
APP_NAME=mitroo
APP_PORT=4000

POSTGRES_USER=mitroo
POSTGRES_PASSWORD=
POSTGRES_DB=mitroo
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mitroo:YOUR_PASSWORD@postgres:5432/mitroo?schema=public
DATABASE_URL_DEV=postgresql://mitroo:YOUR_PASSWORD@localhost:5432/mitroo?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_URL_DEV=redis://localhost:6379

JWT_SECRET=
JWT_EXPIRES_IN=7d

API_BASE_URL=http://localhost:4000/api
FRONTEND_PORT=8080

# ── Web Push (VAPID) ─────────────────────────
VAPID_PUBLIC_KEY=BOrbrfBYKoy74gKA8owaEc4FTzB0u75er_cTyR8WPs-o5YgxuXaAAUgfLQVoXIryJvQT78T4ejVz4bmvBirPidI
VAPID_PRIVATE_KEY=FKrv8F68NMNZxlMgtu7yZfAmMrJnBwAD-G2JIxu1lLM
